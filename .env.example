# NanoClaw Environment Configuration
# Copy this file to .env and fill in your values

# ==============================================
# REQUIRED: Configure at least one platform
# ==============================================

# Discord Bot Configuration
# Get your bot token from: https://discord.com/developers/applications
# 1. Create New Application -> Bot tab -> Reset Token (copy immediately)
# 2. Enable Message Content Intent under Privileged Gateway Intents
# 3. Generate OAuth2 URL with bot scope and invite to your server
DISCORD_BOT_TOKEN=
DISCORD_ONLY=

# Slack Bot Configuration  
# Get your credentials from: https://api.slack.com/apps
# 1. Create New App -> From scratch
# 2. Go to OAuth & Permissions
# 3. Add Bot Token Scopes: chat:write, im:write, channels:history, groups:history, app_mentions:read
# 4. Install to workspace, copy Bot User OAuth Token (starts with xoxb-)
# 5. Go to Basic Information, copy Signing Secret
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ==============================================
# OPTIONAL: Analytics & Logging
# ==============================================

# PostHog Analytics
# Only POSTHOG_API_KEY is required (starts with 'phc_').
# POSTHOG_PROJECT_ID is optional and stored for reference only.
# Get your API key from https://us.posthog.com/project/settings
POSTHOG_PROJECT_ID=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Logging Configuration
# LOG_LEVEL=debug enables dev mode (logs to files + pretty console)
# When not in dev mode and PostHog is configured, logs go to PostHog
# When not in dev mode and PostHog is NOT configured, logs go to files only
LOG_LEVEL=info

# OpenTelemetry Configuration (auto-set when PostHog is configured)
# These are automatically configured when POSTHOG_API_KEY is set.
# Only set these manually if you need custom OTEL configuration:
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=https://us.i.posthog.com/i/v1/logs
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer phc_your_key_here
# OTEL_RESOURCE_ATTRIBUTES=service.name=nanoclaw,service.version=1.0.0

# ==============================================
# OPTIONAL: Admin Configuration
# ==============================================

# Comma-separated list of authorized user IDs who can run admin commands
# Format: discord:<user_id>,slack:<user_id>
# Get Discord user ID: Right-click user in Discord -> Copy User ID (requires Developer Mode)
# Get Slack user ID: Click user profile -> Copy member ID
ADMIN_USER_IDS=

# ==============================================
# OPTIONAL: General Settings
# ==============================================

# Assistant name used in responses and logging
ASSISTANT_NAME=Andy

# Timezone for scheduled tasks (default: system timezone)
# TZ=America/New_York

# Idle timeout for agent runs in milliseconds (default: 30 minutes)
# IDLE_TIMEOUT=1800000

# Maximum concurrent agent runs (default: 5)
# MAX_CONCURRENT_RUNS=5

# SET NAME OF INSTANCE
NANOCLAW_INSTANCE_NAME=DefaultInstance
